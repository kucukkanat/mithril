{
  "name": "mithril-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "for p in core providers memory evals kv otel fs react mithril workflows mcp vectors sandbox devtools create-mithril; do tsc --noEmit -p packages/$p/tsconfig.json || exit 1; done",
    "docs:dev": "bun run --cwd apps/docs dev",
    "docs:build": "bun run --cwd apps/docs build",
    "docs:preview": "bun run --cwd apps/docs preview",
    "docs:check": "bun run --cwd apps/docs check",
    "docs:check-symbols": "bun run apps/docs/scripts/check-symbol-links.ts",
    "docs:check-pages": "bun run apps/docs/scripts/check-orphan-pages.ts",
    "gen-symbols": "bun run apps/docs/scripts/gen-symbols.ts",
    "evals": "bun run --cwd apps/evals eval"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "typescript": "^5.6.0"
  }
}
