---
import { Code } from "astro:components";
import Landing from "../layouts/Landing.astro";
import Pillars from "../components/Pillars.astro";
import Comparison from "../components/Comparison.astro";
import Playground from "../components/Playground.tsx";
import DevtoolsDemo from "../components/DevtoolsDemo.tsx";

const hero = `import { agent, tool } from "mithril";
import { anthropic } from "mithril/anthropic";
import { z } from "zod"; // any Standard Schema validator

const weather = tool({
  name: "weather",
  description: "Current weather for a city.",
  inputSchema: z.object({ city: z.string() }),
  execute: async ({ city }) => ({ city, tempC: 21 }),
});

const assistant = agent({
  model: anthropic("claude-fable-5"), // self-wires the provider
  instructions: "You are a concise weather assistant.",
  tools: [weather],
});

const { output } = await assistant.run("Weather in Istanbul?");`;

const stats = [
  { k: "Node · Bun · Browser", v: "one core" },
  { k: "Zero", v: "runtime deps in core" },
  { k: "12", v: "composable packages" },
  { k: "MIT", v: "OSS-first" },
];
---

<Landing
  title="Mithril — the developer-first AI agent harness"
  description="TypeScript-first, provider-agnostic, and it genuinely runs in the browser. The typed, versioned event stream is the product."
>
  <header class="nav">
    <div class="mth-container nav-inner">
      <a href="/" class="brand"><span class="mth-sheen">Mithril</span></a>
      <nav class="nav-links">
        <a href="/getting-started/introduction/">Docs</a>
        <a href="/playground/">Playground</a>
        <a href="/guides/devtools/">Devtools</a>
        <a href="/reference/">Reference</a>
        <a href="/roadmap/">Roadmap</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero mth-container">
      <div class="hero-copy">
        <p class="mth-eyebrow">TypeScript · Node · Bun · Browser</p>
        <h1 class="hero-title">
          The AI harness<br /><span class="mth-sheen">you can actually read.</span>
        </h1>
        <p class="hero-tagline">
          A ~100-line loop you could copy out, over a tiny web-standards core that runs
          identically on Node, Bun, and browsers — with durable typed suspension,
          trajectory-native evals, and a live inspector.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="/getting-started/introduction/">Get started →</a>
          <a class="btn btn-ghost" href="/playground/">Try the playground</a>
        </div>
        <p class="hero-note">
          <span class="dot"></span> The typed, versioned event stream is the product.
        </p>
      </div>

      <div class="hero-code mth-card">
        <div class="code-frame-bar">
          <span class="tl-dot"></span><span class="tl-dot"></span><span class="tl-dot"></span>
          <span class="code-frame-name">weather-agent.ts</span>
        </div>
        <Code code={hero} lang="ts" theme="github-dark-default" />
      </div>
    </section>

    <!-- STAT STRIP -->
    <section class="mth-container">
      <div class="stats">
        {
          stats.map((s) => (
            <div class="stat">
              <span class="stat-k mth-sheen">{s.k}</span>
              <span class="stat-v">{s.v}</span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- EMBEDDED PLAYGROUND -->
    <section class="mth-container demo">
      <div class="demo-head">
        <p class="mth-eyebrow">Live · zero network · zero keys</p>
        <h2>Run a real agent loop, right here</h2>
        <p class="demo-sub">
          This is the actual framework compiled to the browser — the scripted provider replays
          model turns with no network, and you watch the real <code>MithrilEvent</code> stream.
          Drag the scrubber to time-travel through <code>replay(log, cursor)</code>.
        </p>
      </div>
      <div class="home-pg">
        <Playground client:only="react" embedded={true} />
      </div>
      <p class="demo-more">
        <a href="/playground/">Open the full playground — add your own key or run a local model →</a>
      </p>
    </section>

    <!-- DEVTOOLS SHOWCASE -->
    <section class="mth-container demo">
      <div class="demo-head">
        <p class="mth-eyebrow">React DevTools for agents</p>
        <h2>Now inspect it — state, spans, cost, time-travel</h2>
        <p class="demo-sub">
          Because every run is a typed event stream, you can <em>see</em> it.
          <code>@mithril/devtools</code> renders the live event log, a span tree, cost + context
          meters, and a time-travel scrubber. Add one import — <code>import "mithril/devtools/attach"</code>
          — and every run in the process shows up, no wiring.
        </p>
      </div>
      <div class="home-dev">
        <DevtoolsDemo client:only="react" />
      </div>
      <p class="demo-more">
        <a href="/guides/devtools/">Read the devtools guide →</a>
      </p>
    </section>

    <Pillars />
    <Comparison />

    <!-- POSITIONING / CTA -->
    <section class="mth-container cta">
      <div class="cta-card mth-card">
        <p class="mth-eyebrow">The defensible wedge</p>
        <h2>
          The harness the community keeps saying it wants —<br />
          <span class="mth-sheen">and keeps building by hand.</span>
        </h2>
        <p class="cta-body">
          Not another framework that owns your control flow. A readable loop over a tiny
          web-standards core, with durable typed suspension, trajectory-native evals, context
          engineering, and a free local studio as peer packages. Message against the rewrite
          cliff, not against DIY.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="/getting-started/introduction/">Read the docs →</a>
          <a class="btn btn-ghost" href="/getting-started/installation/">
            <code>bunx create-mithril</code>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="mth-container footer-inner">
      <div>
        <span class="mth-sheen brand-sm">Mithril</span>
        <span class="footer-muted"> · MIT · built with its own React bindings</span>
      </div>
      <nav class="footer-links">
        <a href="/getting-started/introduction/">Docs</a>
        <a href="/playground/">Playground</a>
        <a href="/reference/">API</a>
        <a href="/design/how-mithril-was-designed/">Design</a>
      </nav>
    </div>
  </footer>
</Landing>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(12px);
    background: var(--bg-nav);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  .brand {
    font-size: var(--mth-fs-lg);
    font-weight: var(--mth-weight-semibold);
    letter-spacing: var(--mth-tracking-tight);
  }
  .brand:hover {
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: var(--mth-space-5);
    font-size: var(--mth-fs-sm);
  }
  .nav-links a {
    color: var(--text-muted);
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: var(--mth-space-8);
    align-items: center;
    padding-block: clamp(3rem, 8vh, 6rem);
  }
  .hero-title {
    font-size: var(--mth-fs-5xl);
    line-height: var(--mth-lh-tight);
    letter-spacing: var(--mth-tracking-tighter);
    font-weight: var(--mth-weight-bold);
    margin: var(--mth-space-3) 0 var(--mth-space-4);
  }
  .hero-tagline {
    font-size: var(--mth-fs-lg);
    color: var(--text-muted);
    max-width: 34rem;
    margin-bottom: var(--mth-space-6);
  }
  .hero-cta {
    display: flex;
    gap: var(--mth-space-3);
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--mth-space-2);
    padding: 0.7rem 1.15rem;
    border-radius: var(--mth-radius-md);
    font-size: var(--mth-fs-sm);
    font-weight: var(--mth-weight-semibold);
    border: 1px solid transparent;
    transition:
      transform var(--mth-dur-fast) var(--mth-ease),
      background var(--mth-dur-fast) var(--mth-ease);
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-contrast);
    box-shadow: var(--glow-accent);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
  }
  .btn-ghost {
    background: var(--surface-2);
    color: var(--text);
    border-color: var(--border-strong);
  }
  .btn-ghost:hover {
    background: var(--surface-hover);
  }
  .btn-ghost code {
    font-family: var(--mth-font-mono);
    font-size: 0.9em;
  }
  .hero-note {
    margin-top: var(--mth-space-6);
    font-size: var(--mth-fs-sm);
    color: var(--text-faint);
    display: flex;
    align-items: center;
    gap: var(--mth-space-2);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--mth-mint);
    box-shadow: 0 0 10px var(--mth-mint);
  }

  .hero-code {
    overflow: hidden;
  }
  .code-frame-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
  }
  .tl-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--surface-3);
    border: 1px solid var(--border-strong);
  }
  .code-frame-name {
    margin-left: 0.5rem;
    font-family: var(--mth-font-mono);
    font-size: var(--mth-fs-xs);
    color: var(--text-faint);
  }
  .hero-code :global(pre) {
    margin: 0;
    padding: var(--mth-space-5);
    background: var(--code-bg) !important;
    font-size: var(--mth-fs-sm);
    max-height: 30rem;
    overflow: auto;
  }

  /* Stat strip */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--mth-space-4);
    padding: var(--mth-space-5) var(--mth-space-5);
    border-block: 1px solid var(--border);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .stat-k {
    font-size: var(--mth-fs-xl);
    font-weight: var(--mth-weight-bold);
    letter-spacing: var(--mth-tracking-tight);
  }
  .stat-v {
    font-size: var(--mth-fs-sm);
    color: var(--text-faint);
  }

  /* Embedded playground */
  .demo {
    padding-block: var(--mth-space-10);
  }
  .demo-head {
    max-width: 42rem;
    margin-bottom: var(--mth-space-5);
  }
  .demo-head h2 {
    font-size: var(--mth-fs-3xl);
    letter-spacing: var(--mth-tracking-tight);
    margin: var(--mth-space-3) 0;
  }
  .demo-sub {
    color: var(--text-muted);
    font-size: var(--mth-fs-lg);
  }
  .demo-sub code,
  .demo-more code {
    font-family: var(--mth-font-mono);
    font-size: 0.88em;
    color: var(--accent);
  }
  .home-pg {
    height: 30rem;
    box-shadow: var(--shadow-lg);
    border-radius: var(--mth-radius-lg);
  }
  /* The live devtools inspector, mapped to the site's tokens so it blends with the page. */
  .home-dev :global(.mth-dev) {
    --d-bg: var(--surface);
    --d-surface: var(--surface-2);
    --d-surface-2: var(--surface-3);
    --d-border: var(--border);
    --d-text: var(--text);
    --d-text-muted: var(--text-muted);
    --d-accent: var(--accent);
    --d-mono: var(--mth-font-mono);
    --d-radius: var(--mth-radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .demo-more {
    margin-top: var(--mth-space-4);
    font-size: var(--mth-fs-sm);
  }

  /* CTA */
  .cta {
    padding-block: var(--mth-space-10);
  }
  .cta-card {
    padding: clamp(2rem, 5vw, 4rem);
    text-align: center;
    background:
      radial-gradient(80% 120% at 50% 0%, color-mix(in srgb, var(--accent) 10%, transparent), transparent),
      var(--surface);
  }
  .cta-card h2 {
    font-size: var(--mth-fs-3xl);
    letter-spacing: var(--mth-tracking-tight);
    line-height: var(--mth-lh-snug);
    margin: var(--mth-space-3) 0 var(--mth-space-4);
  }
  .cta-body {
    color: var(--text-muted);
    font-size: var(--mth-fs-lg);
    max-width: 44rem;
    margin: 0 auto var(--mth-space-6);
  }
  .cta .hero-cta {
    justify-content: center;
  }

  .footer {
    border-top: 1px solid var(--border);
    padding-block: var(--mth-space-6);
    margin-top: var(--mth-space-8);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--mth-space-4);
    font-size: var(--mth-fs-sm);
    flex-wrap: wrap;
  }
  .brand-sm {
    font-weight: var(--mth-weight-semibold);
  }
  .footer-muted {
    color: var(--text-faint);
  }
  .footer-links {
    display: flex;
    gap: var(--mth-space-4);
  }
  .footer-links a {
    color: var(--text-muted);
  }

  @media (max-width: 52rem) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--mth-space-6);
    }
    .nav-links {
      display: none;
    }
    .stats {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--mth-space-5);
    }
    .home-pg {
      height: 34rem;
    }
  }
</style>
