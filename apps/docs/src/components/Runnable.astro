---
import { Code } from "@astrojs/starlight/components";
import { encodeCode } from "../playground/share.ts";

interface Props {
  code: string;
  lang?: "ts" | "tsx" | "js" | "jsx" | "json" | "bash" | "sh";
  title?: string;
  /** Set false for snippets that reference real providers / can't run scripted. */
  runnable?: boolean;
  /**
   * A preset id to deep-link to (e.g. "hitl"). When set, "Open in playground" links to `#preset=<id>`, which
   * boots pristine so the Run-against picker still works — preferred over `#code=` for the built-in presets.
   */
  preset?: string;
  /**
   * Lines (or ranges) to highlight as "the relevant piece", e.g. `[3]`, `["5-8"]`, `[2, "6-7"]`.
   * Rendered as Expressive Code marks.
   */
  highlight?: (number | string)[];
}
const { code, lang = "ts", title = "example.ts", runnable = true, preset, highlight } = Astro.props;
const href = !runnable ? null : preset ? `/playground/#preset=${encodeURIComponent(preset)}` : `/playground/#code=${encodeCode(code.trim())}`;
// Expressive Code treats a bare string mark as a text search; a line number/range needs `{ range }`.
const mark = highlight?.map((h) => ({ range: String(h) }));
---

<div class="runnable" data-testid="runnable-block">
  {
    href && (
      <div class="runnable-bar">
        <a class="runnable-run" href={href} data-testid="runnable-block-open-in-playground-link">
          Open in playground ↗
        </a>
      </div>
    )
  }
  <Code code={code.trim()} lang={lang} title={title} mark={mark} />
</div>

<style>
  .runnable {
    position: relative;
    margin: 1rem 0 1.5rem;
  }
  /* Sit the launch button inside the code frame's title bar (right-aligned, opposite
     the filename tab) so it reads as frame chrome instead of floating over the code.
     The bar itself is click-through; only the pill captures clicks. */
  .runnable-bar {
    position: absolute;
    top: 0;
    right: 0;
    height: 2.2rem; /* matches Expressive Code's editor-frame title bar */
    display: flex;
    align-items: center;
    padding-right: 0.6rem;
    z-index: 2;
    pointer-events: none;
  }
  .runnable-run {
    pointer-events: auto;
    font-family: var(--mth-font-mono);
    font-size: var(--mth-fs-xs, 0.75rem);
    line-height: 1;
    color: var(--accent, #6cb8ff);
    text-decoration: none;
    padding: 3px 12px;
    border-radius: var(--mth-radius-full, 9999px);
    border: 1px solid var(--border-accent, rgba(108, 184, 255, 0.45));
    background: var(--sl-color-bg, #0f1218);
    transition: background 0.12s ease;
    white-space: nowrap;
  }
  .runnable-run:hover {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    text-decoration: none;
  }
  /* The Expressive Code frame carries its own copy button, symbol tooltips, and light/dark themes. */
  .runnable :global(.expressive-code) {
    margin: 0;
  }
</style>
